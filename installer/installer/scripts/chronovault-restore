#!/bin/bash
# chronovault Restore - Bash Orchestrator
# Purpose: Mount BACKUP, call Python restore logic, always unmount on exit

set -euo pipefail

# Script paths
SCRIPT_DIR="/opt/chronovault/scripts"
MOUNT_SCRIPT="${SCRIPT_DIR}/chronovault-backup-mount"
UMOUNT_SCRIPT="${SCRIPT_DIR}/chronovault-backup-umount"
PYTHON_SCRIPT="${SCRIPT_DIR}/chronovault_restore.py"
LOG_FILE="/var/log/chronovault/backup.log"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] RESTORE: $*" | tee -a "${LOG_FILE}"
}

# Cleanup function - always runs on exit
cleanup() {
    local exit_code=$?
    
    log "Cleanup: Unmounting BACKUP..."
    
    # Unmount and close BACKUP (ignore errors in cleanup to ensure we try)
    if ! "${UMOUNT_SCRIPT}" 2>/dev/null; then
        log "WARNING: Cleanup unmount had issues (may already be unmounted)"
    fi
    
    if [ ${exit_code} -eq 0 ]; then
        log "restore finished OK"
    else
        log "restore finished with ERROR (exit code: ${exit_code})"
    fi
    
    exit ${exit_code}
}

# Set trap to always run cleanup on exit
trap cleanup EXIT INT TERM

# Main execution
main() {
    log "restore start"
    
    # Parse arguments
    if [ $# -lt 1 ]; then
        echo "Usage: $0 <snapshot_path> [--apps immich nextcloud]"
        echo ""
        echo "Full restore only - restores files + databases from snapshot"
        echo "This ensures files and database stay in sync."
        echo ""
        echo "Examples:"
        echo "  $0 /mnt/backup/chronovault/snapshots/daily/2026-01-15"
        echo "  $0 /mnt/backup/chronovault/snapshots/weekly/2026-03"
        echo "  $0 /mnt/backup/chronovault/snapshots/daily/2026-01-15 --apps immich"
        echo "  $0 /mnt/backup/chronovault/snapshots/daily/2026-01-15 --apps nextcloud"
        exit 1
    fi
    
    # Mount BACKUP disk - capture output and check exit code
    log "Mounting BACKUP disk..."
    local mount_output
    local mount_exit_code
    
    if ! mount_output=$("${MOUNT_SCRIPT}" 2>&1); then
        mount_exit_code=$?
        log "Mount failed (exit code: ${mount_exit_code})"
        log "Mount output: ${mount_output}"
        exit 1
    fi
    
    log "BACKUP mounted successfully"
    
    # Call Python restore script with all arguments
    log "Calling Python restore script..."
    python3 "${PYTHON_SCRIPT}" "$@"
    local restore_exit_code=$?
    
    if [ ${restore_exit_code} -eq 0 ]; then
        log "Restore completed successfully"
    else
        log "Restore failed with exit code: ${restore_exit_code}"
    fi
    
    exit ${restore_exit_code}
}

# Run main function
main "$@"
